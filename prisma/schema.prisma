// ============================================================================
// XXGame — 数据库 Schema
// 基于 Figma 设计稿: XXGame-V1 (z8ontv0eTqv8M1Yk6fKLUw)
// 数据库: PostgreSQL (Supabase 在线数据库)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// 1. users — 用户表
// 对应 Figma: 登录窗口 (16:534)
// 手机号 + 验证码的免密登录方式，手机号作为唯一登录凭证
// role 区分普通用户(user)和管理员(admin)
// ============================================================================
model User {
  id          String   @id @default(uuid()) @db.Uuid
  phone       String   @unique @db.VarChar(20)
  nickname    String?  @db.VarChar(50)
  avatarUrl   String?  @map("avatar_url") @db.Text
  role        String   @default("user") @db.VarChar(10)    // "user" | "admin"
  status      String   @default("active") @db.VarChar(10)  // "active" | "banned"
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  posts              Post[]
  comments           Comment[]
  likes              Like[]
  verificationCodes  VerificationCode[]
  auditLogs          AuditLog[]

  @@map("users")
}

// ============================================================================
// 2. workspaces — 工作区/板块表
// 对应 Figma: 互动列表 List-Item 中的"影视工作区"标签 (16:572)
// 文章分类聚合，如: 影视工作区、游戏讨论区、电竞区 等
// ============================================================================
model Workspace {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(50)                   // 如"影视工作区"
  slug        String   @unique @db.VarChar(50)           // URL 标识，如 yingshi
  description String?  @db.Text                          // 板块描述
  iconUrl     String?  @map("icon_url") @db.Text         // 板块图标
  sortOrder   Int      @default(0) @map("sort_order")    // 前端展示排序
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  posts Post[]

  @@map("workspaces")
}

// ============================================================================
// 3. posts — 文章/互动帖表 (核心表)
// 对应 Figma:
//   - 互动列表: List-Item 卡片 (16:564) — 标题、摘要、内容
//   - 互动发布: Textarea Field (16:632) — 正文输入
// status 流转: draft → under_review → published / rejected → hidden
// like_count / comment_count 为冗余字段，避免每次列表查询 COUNT
// ============================================================================
model Post {
  id           String    @id @default(uuid()) @db.Uuid
  title        String    @db.VarChar(200)
  content      String    @db.Text
  summary      String?   @db.Text                          // 列表卡片摘要，如 Figma 16:570
  authorId     String    @map("author_id") @db.Uuid
  workspaceId  String?   @map("workspace_id") @db.Uuid
  status       String    @default("published") @db.VarChar(15)
  // "draft" | "published" | "under_review" | "rejected" | "hidden"
  isPinned     Boolean   @default(false) @map("is_pinned")
  viewCount    Int       @default(0) @map("view_count")
  likeCount    Int       @default(0) @map("like_count")      // 冗余: 定时同步 likes 表
  commentCount Int       @default(0) @map("comment_count")   // 冗余: 定时同步 comments 表
  publishedAt  DateTime  @default(now()) @map("published_at") @db.Timestamptz()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  images    PostImage[]   // 对应 Figma 互动列表卡片中的 3 张缩略图 (16:566-568)
  comments  Comment[]
  tags      PostTag[]
  auditLogs AuditLog[]

  @@index([workspaceId, status])
  @@index([publishedAt(sort: Desc)])
  @@map("posts")
}

// ============================================================================
// 4. post_images — 文章图片表
// 对应 Figma:
//   - 互动列表卡片: image 1/2/3 (16:566-568) — 每篇贴文最多展示 3 张图
//   - 互动发布: Upload 组件 (16:586) — 上传图片按钮
// sort_order 控制图片在列表中的展示顺序
// ============================================================================
model PostImage {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  imageUrl  String   @map("image_url") @db.Text
  sortOrder Int      @default(0) @map("sort_order")  // 图片排列顺序
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_images")
}

// ============================================================================
// 5. comments — 评论表
// parent_id 自引用支持二级嵌套回复（一级评论 + 子回复）
// like_count 为冗余字段
// ============================================================================
model Comment {
  id        String    @id @default(uuid()) @db.Uuid
  postId    String    @map("post_id") @db.Uuid
  authorId  String    @map("author_id") @db.Uuid
  parentId  String?   @map("parent_id") @db.Uuid       // NULL = 一级评论，非 NULL = 回复某评论
  content   String    @db.Text
  likeCount Int       @default(0) @map("like_count")
  status    String    @default("published") @db.VarChar(10)
  // "published" | "hidden" | "deleted"
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([postId, createdAt])
  @@map("comments")
}

// ============================================================================
// 6. likes — 点赞记录表
// 多态关联: target_type 区分点赞目标（文章/评论）
// UNIQUE 约束保证一人一目标只能点赞一次
// ============================================================================
model Like {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  targetType String   @map("target_type") @db.VarChar(10) // "post" | "comment"
  targetId   String   @map("target_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
  @@map("likes")
}

// ============================================================================
// 7. verification_codes — 短信验证码表
// 对应 Figma: 登录窗口中"请输入验证码"输入框 (18:65)
// 过期时间建议 5 分钟
// ============================================================================
model VerificationCode {
  id        String   @id @default(uuid()) @db.Uuid
  phone     String   @db.VarChar(20)
  code      String   @db.VarChar(10)
  expiresAt DateTime @map("expires_at") @db.Timestamptz()  // 过期时间戳
  used      Boolean  @default(false)                        // 是否已使用
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([phone, createdAt])
  @@map("verification_codes")
}

// ============================================================================
// 辅助表
// ============================================================================

// ----------------------------------------------------------------------------
// 8. tags — 文章标签维度
// ----------------------------------------------------------------------------
model Tag {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique @db.VarChar(30)  // 标签名
  slug      String    @unique @db.VarChar(30)  // URL 标识
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  posts PostTag[]

  @@map("tags")
}

// ----------------------------------------------------------------------------
// 9. post_tags — 文章-标签关联表 (多对多)
// ----------------------------------------------------------------------------
model PostTag {
  postId String @map("post_id") @db.Uuid
  tagId  String @map("tag_id") @db.Uuid

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}

// ----------------------------------------------------------------------------
// 10. audit_logs — 审核操作日志表
// 用于后台管理系统 /admin 的文章审核功能
// ----------------------------------------------------------------------------
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  auditorId String   @map("auditor_id") @db.Uuid   // 执行审核的管理员
  action    String   @db.VarChar(10)                // "approve" | "reject" | "hide"
  reason    String?  @db.Text                       // 审核原因 / 拒绝理由
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  post    Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  auditor User @relation(fields: [auditorId], references: [id])

  @@map("audit_logs")
}
