// ============================================================================
// XXGame — 数据库 Schema
// 基于 Figma 设计稿: XXGame-V1 (z8ontv0eTqv8M1Yk6fKLUw)
// 数据库: PostgreSQL (Supabase)
//
// 鉴权架构:
//   前台用户: 手机号 + 短信验证码登录 (自建，无第三方依赖)
//   后台管理: 邮箱 + 密码登录 (独立体系)
//
// 表结构关系:
//   users ──1:N──→ posts / comments / likes / verification_codes
//   admins (独立) ──1:N──→ audit_logs
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// 1. users — 前台用户表
// 对应 Figma: 登录窗口 (16:534)
// 手机号 + 验证码免密登录，phone 作为唯一登录凭证
// ============================================================================
model User {
  id          String   @id @default(uuid()) @db.Uuid
  phone       String   @unique @db.VarChar(20)
  nickname    String?  @db.VarChar(50)
  avatarUrl   String?  @map("avatar_url") @db.Text
  passwordHash String?  @map("password_hash") @db.Text        // bcrypt hash, NULL = 仅验证码登录
  role        String   @default("user") @db.VarChar(10)    // "user" | "moderator"
  status      String   @default("active") @db.VarChar(10)  // "active" | "banned"
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  posts    Post[]
  comments Comment[]
  likes    Like[]

  @@map("users")
}

// ============================================================================
// 2. verification_codes — 短信验证码表
// 对应 Figma: 登录窗口"请输入验证码"输入框 (18:65)
// 5 分钟过期，used 标记防止重复使用
// ============================================================================
model VerificationCode {
  id        String   @id @default(uuid()) @db.Uuid
  phone     String   @db.VarChar(20)
  code      String   @db.VarChar(10)
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([phone, createdAt])
  @@map("verification_codes")
}

// ============================================================================
// 3. admins — 后台管理员表
// 独立鉴权: email + bcrypt(passwordHash)
// 与前台 users 完全隔离，角色支持 admin / super_admin
// ============================================================================
model Admin {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.Text      // bcrypt hash，应用层处理
  nickname     String   @db.VarChar(50)
  role         String   @default("admin") @db.VarChar(20)   // "admin" | "super_admin"
  status       String   @default("active") @db.VarChar(10)  // "active" | "disabled"
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  auditLogs AuditLog[]

  @@map("admins")
}

// ============================================================================
// 4. workspaces — 工作区/板块表
// 对应 Figma: 互动列表 List-Item 中的"影视工作区"标签 (16:572)
// 文章分类聚合，如: 影视工作区、游戏讨论区、电竞区 等
// ============================================================================
model Workspace {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(50)
  slug        String   @unique @db.VarChar(50)
  description String?  @db.Text
  iconUrl     String?  @map("icon_url") @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  posts Post[]

  @@map("workspaces")
}

// ============================================================================
// 5. posts — 文章/互动帖表 (核心表)
// 对应 Figma:
//   - 互动列表: List-Item 卡片 (16:564) — 标题、摘要、内容
//   - 互动发布: Textarea Field (16:632) — 正文输入
// status 流转: draft → under_review → published / rejected → hidden
// like_count / comment_count 冗余字段，避免每次列表查询 COUNT
// ============================================================================
model Post {
  id           String    @id @default(uuid()) @db.Uuid
  title        String    @db.VarChar(200)
  content      String    @db.Text
  summary      String?   @db.Text                          // 列表卡片摘要，对应 Figma 16:570
  authorId     String    @map("author_id") @db.Uuid
  workspaceId  String?   @map("workspace_id") @db.Uuid
  status       String    @default("published") @db.VarChar(15)
  // "draft" | "published" | "under_review" | "rejected" | "hidden"
  isPinned     Boolean   @default(false) @map("is_pinned")
  viewCount    Int       @default(0) @map("view_count")
  likeCount    Int       @default(0) @map("like_count")
  commentCount Int       @default(0) @map("comment_count")
  publishedAt  DateTime  @default(now()) @map("published_at") @db.Timestamptz()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  workspace Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  images    PostImage[]  // 对应 Figma: 互动列表卡片中的 3 张缩略图 (16:566-568)
  comments  Comment[]
  tags      PostTag[]
  auditLogs AuditLog[]

  @@index([workspaceId, status])
  @@index([publishedAt(sort: Desc)])
  @@map("posts")
}

// ============================================================================
// 6. post_images — 文章图片表
// 对应 Figma:
//   - 互动列表卡片: image 1/2/3 (16:566-568)
//   - 互动发布: Upload 组件 (16:586)
// 图片存储用 Supabase Storage，本表存 URL
// ============================================================================
model PostImage {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  imageUrl  String   @map("image_url") @db.Text
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_images")
}

// ============================================================================
// 7. comments — 评论表
// parent_id 自引用支持二级嵌套（一级评论 + 子回复）
// ============================================================================
model Comment {
  id        String    @id @default(uuid()) @db.Uuid
  postId    String    @map("post_id") @db.Uuid
  authorId  String    @map("author_id") @db.Uuid
  parentId  String?   @map("parent_id") @db.Uuid       // NULL = 一级评论
  content   String    @db.Text
  likeCount Int       @default(0) @map("like_count")
  status    String    @default("published") @db.VarChar(10)
  // "published" | "hidden" | "deleted"
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([postId, createdAt])
  @@map("comments")
}

// ============================================================================
// 8. likes — 点赞记录表
// 多态关联: target_type 区分文章/评论
// UNIQUE 保证一人一目标只能点赞一次
// ============================================================================
model Like {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  targetType String   @map("target_type") @db.VarChar(10) // "post" | "comment"
  targetId   String   @map("target_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
  @@map("likes")
}

// ============================================================================
// 辅助表
// ============================================================================

// ----------------------------------------------------------------------------
// 9. tags — 标签维度
// ----------------------------------------------------------------------------
model Tag {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique @db.VarChar(30)
  slug      String    @unique @db.VarChar(30)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  posts PostTag[]

  @@map("tags")
}

// ----------------------------------------------------------------------------
// 10. post_tags — 文章-标签关联 (多对多)
// ----------------------------------------------------------------------------
model PostTag {
  postId String @map("post_id") @db.Uuid
  tagId  String @map("tag_id") @db.Uuid

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}

// ----------------------------------------------------------------------------
// 11. audit_logs — 审核操作日志
// 后台管理系统 /admin 用，auditorId → admins 表
// ----------------------------------------------------------------------------
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  auditorId String   @map("auditor_id") @db.Uuid   // → admins.id
  action    String   @db.VarChar(10)                // "approve" | "reject" | "hide"
  reason    String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  post    Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  auditor Admin @relation(fields: [auditorId], references: [id])

  @@map("audit_logs")
}
